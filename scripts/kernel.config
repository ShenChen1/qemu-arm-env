# Minimal AArch64 configuration for QEMU's "virt" machine.
#
# This fragment is applied on top of allnoconfig. Keep additions limited to
# features required by the VM or its kernel-debugging workflow.

# Build profile
CONFIG_LOCALVERSION_AUTO=n
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_HZ_100=y
CONFIG_HZ_250=n
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_VA_BITS_52=n
CONFIG_ARM64_PA_BITS_48=y
CONFIG_ARM64_PA_BITS_52=n
CONFIG_NR_CPUS=8
CONFIG_RANDOMIZE_BASE=n

# Basic userspace and systemd support
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_POSIX_TIMERS=y
CONFIG_MULTIUSER=y
CONFIG_FHANDLE=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_COREDUMP=y
CONFIG_ELF_CORE=y
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_EXPERT=y
CONFIG_TTY=y
CONFIG_VT=n
CONFIG_UNIX98_PTYS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_FILE_LOCKING=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SHMEM=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_RSEQ=y
CONFIG_PROC_SYSCTL=y

# Keep module loading available for driver development, but build VM drivers in.
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# systemd and container primitives
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Device tree, PCI, and QEMU virt hardware
CONFIG_OF=y
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PL031=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Virtio disk, network, console, and host directory sharing
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_NET_9P=y
CONFIG_NET_9P_FD=n
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Root filesystem and pseudo filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_NETWORK_FILESYSTEMS=y

# IPv4 networking and kernel DHCP for the QEMU command line
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# eBPF, tracing, perf, and kernel debugging
CONFIG_DEBUG_KERNEL=y
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_KPROBES=y
CONFIG_UPROBES=y
CONFIG_PERF_EVENTS=y
CONFIG_ARM_PMU=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_BPF_EVENTS=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_NONE=n
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=n
CONFIG_GDB_SCRIPTS=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_KALLSYMS=y
CONFIG_MAGIC_SYSRQ=y

# Explicitly reject broad platform features that can pull in driver families.
CONFIG_ACPI=n
CONFIG_EFI=n
CONFIG_COMPAT=n
CONFIG_KEXEC=n
CONFIG_CRASH_DUMP=n
CONFIG_HIBERNATION=n
CONFIG_SUSPEND=n
CONFIG_CPU_FREQ=n
CONFIG_CPU_IDLE=n
CONFIG_NUMA=n
CONFIG_MEMORY_HOTPLUG=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_IOMMU_SUPPORT=n
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_INPUT=n
CONFIG_HID=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_BT=n
CONFIG_ETHERNET=n
CONFIG_SCSI=n
CONFIG_ATA=n
CONFIG_BLK_DEV_NVME=n
CONFIG_MD=n
CONFIG_MTD=n
CONFIG_I2C=n
CONFIG_SPI=n
CONFIG_GPIOLIB=n
CONFIG_MFD_CORE=n
CONFIG_THERMAL=n
CONFIG_HWMON=n
CONFIG_WATCHDOG=n
CONFIG_NEW_LEDS=n
CONFIG_REGULATOR=n
CONFIG_PWM=n
CONFIG_IIO=n
CONFIG_INFINIBAND=n
CONFIG_CAN=n
CONFIG_NFC=n
CONFIG_NETFILTER=n
CONFIG_HW_RANDOM_ARM_SMCCC_TRNG=n
